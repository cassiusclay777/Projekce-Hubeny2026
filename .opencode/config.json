{
  "model": "deepseek-chat",
  "provider": "deepseek",
  "apiKey": "${DEEPSEEK_API_KEY}",
  "apiBaseUrl": "https://api.deepseek.com",
  "temperature": 0.7,
  "maxTokens": 4096,
  "contextWindow": 128000,
  "soulPath": ".opencode/soul",
  "autoLoadSoul": true,
  "terminalMode": true,
  "editorIntegration": {
    "cursor": true,
    "vscode": true,
    "defaultTerminal": "powershell"
  },
  "gitIntegration": {
    "autoCommitMessages": false,
    "reviewChanges": true,
    "suggestCommits": true
  },
  "projectSpecific": {
    "framework": "nextjs",
    "typescript": true,
    "tailwind": true,
    "reactVersion": "19"
  }
}