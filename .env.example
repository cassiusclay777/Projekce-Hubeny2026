# Zkopíruj na `.env` nebo `.env.local` a doplň hodnoty. Tento soubor nikdy neukládej s pravými klíči.
#
# --- Vercel (zkopíruj názvy + hodnoty ručně) ---------------------------------
# Dashboard: projekt → Settings → Environment Variables
# Doporučení: Production i Preview (aspoň pro staging URL).
# Spis názvů:  npm run vercel:env
#
# Povinné pro AI asistenta:     DEEPSEEK_API_KEY
# Volitelné AI:                DEEPSEEK_MODEL, DEEPSEEK_API_BASE_URL
# Povinné pro kontakt + PDF:   RESEND_API_KEY, RESEND_FROM_EMAIL, ORDER_NOTIFY_EMAIL
# Veřejná URL webu:            NEXT_PUBLIC_APP_URL  (https://… nebo https://….vercel.app)

# =============================================================================
# DeepSeek — AI asistent (projektant)
# =============================================================================
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# OpenAI-kompatibilní endpoint (výchozí DeepSeek)
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# deepseek-chat | deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# =============================================================================
# Poptávky z formuláře — e-mail projektantovi (Radim)
# =============================================================================
ORDER_NOTIFY_EMAIL=info@projekce-hubeny.cz

# =============================================================================
# Resend — odesílání e-mailů z /api/contact
# =============================================================================
# https://resend.com — ověř doménu odesílatele
RESEND_API_KEY=
RESEND_FROM_EMAIL="Ing. Radim Hubený <noreply@projekce-hubeny.cz>"

# =============================================================================
# Veřejná URL (odkazy v e-mailech)
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3026
